# ── Binance API 키 ──────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── 테스트넷 설정 ────────────────────────────────────────────
# true  → testnet.binance.vision (현물 테스트넷, dry-run 전용)
#          API 키: testnet.binance.vision 에서 발급
# false → 실거래 선물 API
#          API 키: binance.com > API Management > 선물 권한 필요
USE_TESTNET=true

# ── 텔레그램 알림 ────────────────────────────────────────────
# 1. @BotFather → /newbot → 토큰 발급
# 2. 봇에게 메시지 한 번 보내기
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → chat_id 확인
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
